# 复制为 backend/.env 后填写。不要提交真实密钥。
STUDYWISE_PADDLEOCR_API_TOKEN=
STUDYWISE_OPENAI_API_KEY=
STUDYWISE_DEEPSEEK_API_KEY=
STUDYWISE_ANTHROPIC_API_KEY=

STUDYWISE_PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
STUDYWISE_PADDLEOCR_MODEL=PaddleOCR-VL-1.6
STUDYWISE_PADDLEOCR_POLL_INTERVAL_SECONDS=5
STUDYWISE_PADDLEOCR_TIMEOUT_SECONDS=120
STUDYWISE_PADDLEOCR_USE_DOC_ORIENTATION_CLASSIFY=false
STUDYWISE_PADDLEOCR_USE_DOC_UNWARPING=false
STUDYWISE_PADDLEOCR_USE_CHART_RECOGNITION=false
STUDYWISE_PADDLEOCR_PRETTIFY_MARKDOWN=false

# STUDYWISE_DATA_DIR=C:/somewhere/else/data
# STUDYWISE_CORS_ORIGINS=["http://localhost:5173","http://localhost:1420"]
